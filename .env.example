BOT_TOKEN=your_telegram_bot_token_here

# ⚠️  Inside Docker: use service names (postgres, redis)
# ⚠️  Outside Docker / local: use localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mathtrainer
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=DEBUG

# Comma-separated or JSON array — both formats work:
# ADMIN_IDS=123456789,987654321
# ADMIN_IDS=[123456789, 987654321]
ADMIN_IDS=[123456789]

WEBAPP_URL=https://your-domain.com/static/index.html
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
WEBAPP_ALLOWED_ORIGINS=["https://web.telegram.org","https://your-domain.com"]
WEBAPP_AUTH_MODE=telegram_strict
WEBAPP_INIT_DATA_TTL_SECONDS=600
WEBAPP_ENABLE_HSTS=false
WEBAPP_CSP=default-src 'self'; script-src 'self' https://telegram.org https://*.telegram.org; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; frame-ancestors 'self' https://web.telegram.org https://*.telegram.org; base-uri 'self'; form-action 'self'
WEBAPP_RATE_LIMIT_WINDOW_SECONDS=60
WEBAPP_RATE_LIMIT_SENSITIVE_PER_WINDOW=20
WEBAPP_MAX_REQUEST_BYTES=2097152

# S3 Storage (MinIO)
# S3_ENDPOINT_URL — INTERNAL URL (used by bot/webapp containers to talk to MinIO)
#   Inside Docker: use service name, e.g. http://minio:9000
#   Outside Docker (local dev): use http://localhost:9000
# S3_PUBLIC_URL — PUBLIC URL (used in presigned links opened by browser/Telegram)
#   Same as localhost if MinIO port is exposed, or your CDN/domain in production
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=change-me-access-key
S3_SECRET_KEY=change-me-secret-key
S3_BUCKET_NAME=mathtrainer
S3_PUBLIC_URL=http://localhost:9000
MINIO_ROOT_USER=change-me-root-user
MINIO_ROOT_PASSWORD=change-me-root-password
MINIO_BUCKET_PUBLIC=false
POSTGRES_DB=mathtrainer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password
