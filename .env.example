BOT_TOKEN=your_telegram_bot_token_here

# ⚠️  Inside Docker: use service names (postgres, redis)
# ⚠️  Outside Docker / local: use localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mathtrainer
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=DEBUG

# Comma-separated or JSON array — both formats work:
# ADMIN_IDS=123456789,987654321
# ADMIN_IDS=[123456789, 987654321]
ADMIN_IDS=[123456789]

WEBAPP_URL=https://your-domain.com/static/index.html
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# S3 Storage (MinIO default)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=mathtrainer
S3_PUBLIC_URL=http://localhost:9000
